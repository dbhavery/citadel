# Citadel AI Operations Platform
# ================================
# Copy this file to .env and fill in your values.

# LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Ollama (local)
OLLAMA_URL=http://localhost:11434

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_CACHE_ENABLED=true
GATEWAY_CACHE_TTL=3600

# Trace
TRACE_DB_PATH=./data/traces.db

# Vector
VECTOR_STORAGE_PATH=./data/vectors

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000

# Alerts
ALERT_WEBHOOK_URL=
ALERT_DAILY_COST_LIMIT=10.00
ALERT_ERROR_RATE_THRESHOLD=5.0
